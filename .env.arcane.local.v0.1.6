# Local beta-led environment for the Tigers platform.
# Same release tags as Arcane beta, but local URLs and localhost cookie settings.

COMPOSE_PROJECT_NAME=tigers-local
TZ=Europe/Zurich
LOG_LEVEL=INFO
GHCR_REGISTRY=ghcr.io
GHCR_OWNER=thun-tigers

TT_INFRA_IMAGE_TAG=v0.1.6
TT_AUTH_IMAGE_TAG=v0.1.6
TT_MEMBERS_IMAGE_TAG=v0.1.6
TT_AGENDA_IMAGE_TAG=v0.1.6
TT_ANALYTICS_IMAGE_TAG=v0.1.6
TT_ATTENDANCE_IMAGE_TAG=v0.1.6

INFRA_AUTH_BASE_URL=http://localhost:8085
AUTH_BASE_URL=http://localhost:8085
MEMBERS_AUTH_BASE_URL=http://localhost:8085
AGENDA_AUTH_BASE_URL=http://localhost:8085
ANALYTICS_AUTH_BASE_URL=http://localhost:8085
ATTENDANCE_AUTH_BASE_URL=http://localhost:8085

DEFAULT_MEMBERS_URL=http://localhost:8088
DEFAULT_AGENDA_URL=http://localhost:8086
DEFAULT_ANALYTICS_URL=http://localhost:8087
DEFAULT_ATTENDANCE_URL=http://localhost:8089

JWT_COOKIE_DOMAIN=localhost
JWT_COOKIE_SECURE=false
TT_HOST_BIND_IP=127.0.0.1

INFRA_SECRET_KEY=change-me-infra-secret
AUTH_SECRET_KEY=change-me-auth-secret
MEMBERS_SECRET_KEY=change-me-members-secret
AGENDA_SECRET_KEY=change-me-agenda-secret
ANALYTICS_SECRET_KEY=change-me-analytics-secret
ATTENDANCE_SECRET_KEY=change-me-attendance-secret

SSO_SHARED_SECRET=change-me-sso-shared-secret
INTERNAL_API_SECRET=change-me-internal-api-secret

POSTGRES_INFRA_PASSWORD=change-me-postgres-infra-password
POSTGRES_AUTH_PASSWORD=change-me-postgres-auth-password
POSTGRES_MEMBERS_PASSWORD=change-me-postgres-members-password
POSTGRES_AGENDA_PASSWORD=change-me-postgres-agenda-password
POSTGRES_ANALYTICS_PASSWORD=change-me-postgres-analytics-password
POSTGRES_ATTENDANCE_PASSWORD=change-me-postgres-attendance-password

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
CREATE_DEFAULT_USERS=true
