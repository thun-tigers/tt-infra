# Vorlage für die Produktionsumgebung
# Kopiere diese Datei als .env.prod (wird von .gitignore ausgeschlossen):
#   cp .env.prod.example .env.prod
#
# Verwendung:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

COMPOSE_PROJECT_NAME=tigers-prod
TZ=Europe/Zurich
LOG_LEVEL=INFO

# ── Image Tags ─────────────────────────────────────────────────────────────────
# Normalerweise 'latest' oder ein spezifischer Version-Tag wie 'v0.1.19'
TT_INFRA_IMAGE_TAG=latest
TT_AUTH_IMAGE_TAG=latest
TT_MEMBERS_IMAGE_TAG=latest
TT_AGENDA_IMAGE_TAG=latest
TT_ANALYTICS_IMAGE_TAG=latest
TT_ATTENDANCE_IMAGE_TAG=latest
TT_POSTGRES_IMAGE_TAG=latest

# ── Shared Secrets ─────────────────────────────────────────────────────────────
SSO_SHARED_SECRET=
INTERNAL_API_SECRET=

# ── Infra ──────────────────────────────────────────────────────────────────────
INFRA_SECRET_KEY=
INFRA_DATABASE_URL=postgresql+psycopg://tt_infra:CHANGE_ME@tt-postgres:5432/tt_infra

# ── Auth ───────────────────────────────────────────────────────────────────────
AUTH_SECRET_KEY=
AUTH_DATABASE_URL=postgresql+psycopg://tt_auth:CHANGE_ME@tt-postgres:5432/tt_auth
JWT_EXPIRY_HOURS=8
JWT_COOKIE_DOMAIN=.thun-tigers.net
JWT_COOKIE_SECURE=true
SSO_TOKEN_EXPIRY_SECONDS=60
CREATE_DEFAULT_USERS=false
CREATE_DEFAULT_SERVICES=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=

# ── Members ────────────────────────────────────────────────────────────────────
MEMBERS_SECRET_KEY=
MEMBERS_DATABASE_URL=postgresql+psycopg://tt_members:CHANGE_ME@tt-postgres:5432/tt_members

# ── Agenda ─────────────────────────────────────────────────────────────────────
AGENDA_SECRET_KEY=
AGENDA_DATABASE_URL=postgresql+psycopg://tt_agenda:CHANGE_ME@tt-postgres:5432/tt_agenda
AGENDA_WEBHOOK_ENABLED=false
AGENDA_WEBHOOK_URL=
AGENDA_SSO_AUTO_PROVISION_USERS=true
AGENDA_SSO_SYNC_ROLE=true

# ── Analytics ──────────────────────────────────────────────────────────────────
ANALYTICS_SECRET_KEY=
ANALYTICS_DATABASE_URL=postgresql+psycopg://tt_analytics:CHANGE_ME@tt-postgres:5432/tt_analytics
ANALYTICS_SSO_AUTO_PROVISION_USERS=true
ANALYTICS_SSO_SYNC_ROLE=true
ANALYTICS_MAX_CONTENT_LENGTH=2147483648
ANALYTICS_GEMINI_API_KEY=
ANALYTICS_GEMINI_MODEL=gemini-2.5-flash
ANALYTICS_GEMINI_FILE_POLL_SECONDS=5
ANALYTICS_GEMINI_FILE_POLL_TIMEOUT_SECONDS=300
ANALYTICS_GEMINI_MAX_RETRIES=8
ANALYTICS_GEMINI_RETRY_BUFFER_SECONDS=5
ANALYTICS_GEMINI_RETRY_DEFAULT_SECONDS=60

# ── Attendance ─────────────────────────────────────────────────────────────────
ATTENDANCE_SECRET_KEY=
ATTENDANCE_DATABASE_URL=postgresql+psycopg://tt_attendance:CHANGE_ME@tt-postgres:5432/tt_attendance

# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_INFRA_DB=tt_infra
POSTGRES_INFRA_USER=tt_infra
POSTGRES_INFRA_PASSWORD=

POSTGRES_AUTH_DB=tt_auth
POSTGRES_AUTH_USER=tt_auth
POSTGRES_AUTH_PASSWORD=

POSTGRES_MEMBERS_DB=tt_members
POSTGRES_MEMBERS_USER=tt_members
POSTGRES_MEMBERS_PASSWORD=

POSTGRES_AGENDA_DB=tt_agenda
POSTGRES_AGENDA_USER=tt_agenda
POSTGRES_AGENDA_PASSWORD=

POSTGRES_ANALYTICS_DB=tt_analytics
POSTGRES_ANALYTICS_USER=tt_analytics
POSTGRES_ANALYTICS_PASSWORD=

POSTGRES_ATTENDANCE_DB=tt_attendance
POSTGRES_ATTENDANCE_USER=tt_attendance
POSTGRES_ATTENDANCE_PASSWORD=
