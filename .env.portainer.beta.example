GHCR_OWNER=swisi
GHCR_REGISTRY=ghcr.io

TT_INFRA_IMAGE_TAG=beta
TT_AUTH_IMAGE_TAG=beta
TT_MEMBERS_IMAGE_TAG=beta
TT_AGENDA_IMAGE_TAG=beta
TT_ANALYTICS_IMAGE_TAG=beta

TZ=Europe/Zurich
LOG_LEVEL=INFO
TT_INFRA_HTTP_PORT=6084
TT_AUTH_HTTP_PORT=6085
TT_AGENDA_HTTP_PORT=6086
TT_ANALYTICS_HTTP_PORT=6087
TT_MEMBERS_HTTP_PORT=6088

INFRA_SECRET_KEY=beta-infra-secret-key-change-me
INFRA_DATABASE_URL=sqlite:////app/instance/infra.db
INTERNAL_API_SECRET=beta-internal-api-secret-change-me
SSO_SHARED_SECRET=beta-sso-shared-secret-change-me

AUTH_SECRET_KEY=beta-auth-secret-key-change-me
AUTH_DATABASE_URL=postgresql+psycopg://tt_auth:BetaAuthDb123!@tt-postgres-auth:5432/tt_auth_beta
JWT_EXPIRY_HOURS=8
JWT_COOKIE_DOMAIN=.thun-tigers.net
JWT_COOKIE_SECURE=true
SSO_TOKEN_EXPIRY_SECONDS=60
CREATE_DEFAULT_USERS=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=BetaAdmin123!
DEFAULT_MEMBERS_URL=https://members-beta.thun-tigers.net
DEFAULT_AGENDA_URL=https://agenda-beta.thun-tigers.net
DEFAULT_ANALYTICS_URL=https://analytics-beta.thun-tigers.net

MEMBERS_SECRET_KEY=beta-members-secret-key-change-me
MEMBERS_DATABASE_URL=sqlite:////app/instance/members.db
MEMBERS_AUTH_BASE_URL=https://auth-beta.thun-tigers.net

AGENDA_SECRET_KEY=beta-agenda-secret-key-change-me
AGENDA_DATABASE_URL=postgresql+psycopg://tt_agenda:BetaAgendaDb123!@tt-postgres-agenda:5432/tt_agenda_beta
AGENDA_AUTH_BASE_URL=https://auth-beta.thun-tigers.net
AGENDA_WEBHOOK_ENABLED=false
AGENDA_WEBHOOK_URL=
AGENDA_SSO_AUTO_PROVISION_USERS=true
AGENDA_SSO_SYNC_ROLE=true

ANALYTICS_SECRET_KEY=beta-analytics-secret-key-change-me
ANALYTICS_DATABASE_URL=postgresql+psycopg://tt_analytics:BetaAnalyticsDb123!@tt-postgres-analytics:5432/tt_analytics_beta
ANALYTICS_AUTH_BASE_URL=https://auth-beta.thun-tigers.net
ANALYTICS_SSO_AUTO_PROVISION_USERS=true
ANALYTICS_SSO_SYNC_ROLE=true
ANALYTICS_MAX_CONTENT_LENGTH=2147483648
ANALYTICS_GEMINI_API_KEY=
ANALYTICS_GEMINI_MODEL=gemini-2.5-flash
ANALYTICS_GEMINI_FILE_POLL_SECONDS=5
ANALYTICS_GEMINI_FILE_POLL_TIMEOUT_SECONDS=300
ANALYTICS_GEMINI_MAX_RETRIES=8
ANALYTICS_GEMINI_RETRY_BUFFER_SECONDS=5
ANALYTICS_GEMINI_RETRY_DEFAULT_SECONDS=60

POSTGRES_AUTH_DB=tt_auth_beta
POSTGRES_AUTH_USER=tt_auth
POSTGRES_AUTH_PASSWORD=BetaAuthDb123!
POSTGRES_AGENDA_DB=tt_agenda_beta
POSTGRES_AGENDA_USER=tt_agenda
POSTGRES_AGENDA_PASSWORD=BetaAgendaDb123!
POSTGRES_ANALYTICS_DB=tt_analytics_beta
POSTGRES_ANALYTICS_USER=tt_analytics
POSTGRES_ANALYTICS_PASSWORD=BetaAnalyticsDb123!
