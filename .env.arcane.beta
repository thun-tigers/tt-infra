# Core
COMPOSE_PROJECT_NAME=tigers-beta
TZ=Europe/Zurich
LOG_LEVEL=INFO
GHCR_REGISTRY=ghcr.io
GHCR_OWNER=thun-tigers
TT_HOST_BIND_IP=172.17.0.1

# Images
TT_INFRA_IMAGE_TAG=v0.1.8
TT_AUTH_IMAGE_TAG=v0.1.8
TT_MEMBERS_IMAGE_TAG=v0.1.8
TT_AGENDA_IMAGE_TAG=v0.1.8
TT_ANALYTICS_IMAGE_TAG=v0.1.8
TT_ATTENDANCE_IMAGE_TAG=v0.1.8

# Secrets
INFRA_SECRET_KEY=change-me-infra-secret
AUTH_SECRET_KEY=change-me-auth-secret
MEMBERS_SECRET_KEY=change-me-members-secret
AGENDA_SECRET_KEY=change-me-agenda-secret
ANALYTICS_SECRET_KEY=change-me-analytics-secret
ATTENDANCE_SECRET_KEY=change-me-attendance-secret
SSO_SHARED_SECRET=change-me-sso-shared-secret
INTERNAL_API_SECRET=change-me-internal-api-secret

# Beta URLs
AUTH_BASE_URL=https://beta.thun-tigers.net
DEFAULT_MEMBERS_URL=https://members-beta.thun-tigers.net
DEFAULT_AGENDA_URL=https://agenda-beta.thun-tigers.net
DEFAULT_ANALYTICS_URL=https://analytics-beta.thun-tigers.net
DEFAULT_ATTENDANCE_URL=https://attendance-beta.thun-tigers.net
JWT_COOKIE_DOMAIN=.thun-tigers.net
JWT_COOKIE_SECURE=true
CREATE_DEFAULT_USERS=false
CREATE_DEFAULT_SERVICES=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-admin-password

# Internal URLs
DEFAULT_MEMBERS_INTERNAL_URL=http://tt-members:5000
DEFAULT_AGENDA_INTERNAL_URL=http://tt-agenda:5000
DEFAULT_ANALYTICS_INTERNAL_URL=http://tt-analytics:5000
DEFAULT_INFRA_INTERNAL_URL=http://tt-infra:5000
DEFAULT_ATTENDANCE_INTERNAL_URL=http://tt-attendance:5000
TT_AUTH_INTERNAL_URL=http://tt-auth:5000
TT_MEMBERS_INTERNAL_URL=http://tt-members:5000
TT_AGENDA_INTERNAL_URL=http://tt-agenda:5000
TT_ANALYTICS_INTERNAL_URL=http://tt-analytics:5000
TT_ATTENDANCE_INTERNAL_URL=http://tt-attendance:5000
TT_INFRA_INTERNAL_URL=http://tt-infra:5000

# Infra
INFRA_DATABASE_URL=postgresql+psycopg://tt_infra:change-me@tt-postgres-infra:5432/tt_infra_beta
MEMBERS_INSTANCE_DIR=/backup-sources/tt-members-instance
ANALYTICS_UPLOAD_ROOT=/backup-sources/tt-analytics-uploads

# Auth
AUTH_DATABASE_URL=postgresql+psycopg://tt_auth:change-me@tt-postgres-auth:5432/tt_auth_beta
JWT_EXPIRY_HOURS=8
SSO_TOKEN_EXPIRY_SECONDS=60

# Members
MEMBERS_DATABASE_URL=postgresql+psycopg://tt_members:change-me@tt-postgres-members:5432/tt_members_beta
MEMBERS_SSO_EXPECTED_AUDIENCE=tt-members

# Agenda
AGENDA_DATABASE_URL=postgresql+psycopg://tt_agenda:change-me@tt-postgres-agenda:5432/tt_agenda_beta
AGENDA_WEBHOOK_ENABLED=false
AGENDA_WEBHOOK_URL=
AGENDA_SSO_EXPECTED_AUDIENCE=tt-agenda
AGENDA_SSO_AUTO_PROVISION_USERS=true
AGENDA_SSO_SYNC_ROLE=true

# Analytics
ANALYTICS_DATABASE_URL=postgresql+psycopg://tt_analytics:change-me@tt-postgres-analytics:5432/tt_analytics_beta
ANALYTICS_SSO_EXPECTED_AUDIENCE=tt-analytics
ANALYTICS_SSO_AUTO_PROVISION_USERS=true
ANALYTICS_SSO_SYNC_ROLE=true
ANALYTICS_MAX_CONTENT_LENGTH=2147483648
ANALYTICS_GEMINI_API_KEY=
ANALYTICS_GEMINI_MODEL=gemini-2.5-flash
ANALYTICS_GEMINI_FILE_POLL_SECONDS=5
ANALYTICS_GEMINI_FILE_POLL_TIMEOUT_SECONDS=300
ANALYTICS_GEMINI_MAX_RETRIES=8
ANALYTICS_GEMINI_RETRY_BUFFER_SECONDS=5
ANALYTICS_GEMINI_RETRY_DEFAULT_SECONDS=60

# Attendance
ATTENDANCE_DATABASE_URL=postgresql+psycopg://tt_attendance:change-me@tt-postgres-attendance:5432/tt_attendance_beta
ATTENDANCE_SSO_EXPECTED_AUDIENCE=tt-attendance

# Postgres
POSTGRES_INFRA_DB=tt_infra_beta
POSTGRES_INFRA_USER=tt_infra
POSTGRES_INFRA_PASSWORD=change-me-postgres-infra-password
POSTGRES_AUTH_DB=tt_auth_beta
POSTGRES_AUTH_USER=tt_auth
POSTGRES_AUTH_PASSWORD=change-me-postgres-auth-password
POSTGRES_MEMBERS_DB=tt_members_beta
POSTGRES_MEMBERS_USER=tt_members
POSTGRES_MEMBERS_PASSWORD=change-me-postgres-members-password
POSTGRES_AGENDA_DB=tt_agenda_beta
POSTGRES_AGENDA_USER=tt_agenda
POSTGRES_AGENDA_PASSWORD=change-me-postgres-agenda-password
POSTGRES_ANALYTICS_DB=tt_analytics_beta
POSTGRES_ANALYTICS_USER=tt_analytics
POSTGRES_ANALYTICS_PASSWORD=change-me-postgres-analytics-password
POSTGRES_ATTENDANCE_DB=tt_attendance_beta
POSTGRES_ATTENDANCE_USER=tt_attendance
POSTGRES_ATTENDANCE_PASSWORD=change-me-postgres-attendance-password
