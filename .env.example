# Local development stack
# Use with:
#   cp .env.example .env
#   docker compose -f docker-compose.yml -f docker-compose.local.yml up -d --build

# Core
COMPOSE_PROJECT_NAME=tigers-local
TZ=Europe/Zurich
LOG_LEVEL=INFO

# Infra
INFRA_DATABASE_URL=postgresql+psycopg://tt_infra:tt_infra_password@tt-postgres-infra:5432/tt_infra
POSTGRES_INFRA_DB=tt_infra
POSTGRES_INFRA_USER=tt_infra
POSTGRES_INFRA_PASSWORD=tt_infra_password

# Auth
AUTH_PORT=8085
AUTH_BASE_URL=http://localhost:8085
AUTH_SECRET_KEY=change-me-auth-secret
AUTH_DATABASE_URL=postgresql+psycopg://tt_auth:tt_auth_password@tt-postgres-auth:5432/tt_auth
JWT_EXPIRY_HOURS=8
JWT_COOKIE_DOMAIN=localhost
JWT_COOKIE_SECURE=false
SSO_SHARED_SECRET=change-me-sso-shared-secret
SSO_TOKEN_EXPIRY_SECONDS=60
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
DEFAULT_MEMBERS_URL=http://localhost:8088
DEFAULT_AGENDA_URL=http://localhost:8086
DEFAULT_ANALYTICS_URL=http://localhost:8087
DEFAULT_MEMBERS_INTERNAL_URL=http://tt-members:5000
DEFAULT_AGENDA_INTERNAL_URL=http://tt-agenda:5000
DEFAULT_ANALYTICS_INTERNAL_URL=http://tt-analytics:5000
TT_INFRA_INTERNAL_URL=http://tt-infra:5000

# Members
MEMBERS_AUTH_BASE_URL=${AUTH_BASE_URL}
MEMBERS_DATABASE_URL=postgresql+psycopg://tt_members:tt_members_password@tt-postgres-members:5432/tt_members

# Agenda
AGENDA_PORT=8086
AGENDA_SECRET_KEY=change-me-agenda-secret
AGENDA_DATABASE_URL=postgresql+psycopg://tt_agenda:tt_agenda_password@tt-postgres-agenda:5432/tt_agenda
AGENDA_AUTH_BASE_URL=${AUTH_BASE_URL}
AGENDA_WEBHOOK_ENABLED=false
AGENDA_WEBHOOK_URL=https://example.invalid/webhook
AGENDA_SSO_EXPECTED_AUDIENCE=tt-agenda
AGENDA_SSO_AUTO_PROVISION_USERS=true
AGENDA_SSO_SYNC_ROLE=true

# Analytics
ANALYTICS_PORT=8087
ANALYTICS_SECRET_KEY=change-me-analytics-secret
ANALYTICS_DATABASE_URL=postgresql+psycopg://tt_analytics:tt_analytics_password@tt-postgres-analytics:5432/tt_analytics
ANALYTICS_AUTH_BASE_URL=${AUTH_BASE_URL}
ANALYTICS_SSO_EXPECTED_AUDIENCE=tt-analytics
ANALYTICS_SSO_AUTO_PROVISION_USERS=true
ANALYTICS_SSO_SYNC_ROLE=true
ANALYTICS_UPLOAD_ROOT=/app/instance/uploads

# Attendance
ATTENDANCE_PORT=8089
ATTENDANCE_SECRET_KEY=change-me-attendance-secret
ATTENDANCE_DATABASE_URL=postgresql+psycopg://tt_attendance:tt_attendance_password@tt-postgres-attendance:5432/tt_attendance
ATTENDANCE_AUTH_BASE_URL=${AUTH_BASE_URL}
ATTENDANCE_SSO_EXPECTED_AUDIENCE=tt-attendance
INTERNAL_API_SECRET=change-me-internal-api-secret
ANALYTICS_MAX_CONTENT_LENGTH=2147483648
ANALYTICS_GEMINI_API_KEY=
ANALYTICS_GEMINI_MODEL=gemini-2.5-flash
ANALYTICS_GEMINI_FILE_POLL_SECONDS=5
ANALYTICS_GEMINI_FILE_POLL_TIMEOUT_SECONDS=300
ANALYTICS_GEMINI_MAX_RETRIES=8
ANALYTICS_GEMINI_RETRY_BUFFER_SECONDS=5
ANALYTICS_GEMINI_RETRY_DEFAULT_SECONDS=60

# Postgres
POSTGRES_AUTH_DB=tt_auth
POSTGRES_AUTH_USER=tt_auth
POSTGRES_AUTH_PASSWORD=tt_auth_password

POSTGRES_MEMBERS_DB=tt_members
POSTGRES_MEMBERS_USER=tt_members
POSTGRES_MEMBERS_PASSWORD=tt_members_password

POSTGRES_AGENDA_DB=tt_agenda
POSTGRES_AGENDA_USER=tt_agenda
POSTGRES_AGENDA_PASSWORD=tt_agenda_password

POSTGRES_ANALYTICS_DB=tt_analytics
POSTGRES_ANALYTICS_USER=tt_analytics
POSTGRES_ANALYTICS_PASSWORD=tt_analytics_password

POSTGRES_ATTENDANCE_DB=tt_attendance
POSTGRES_ATTENDANCE_USER=tt_attendance
POSTGRES_ATTENDANCE_PASSWORD=tt_attendance_password

# Redis (Rate Limiting)
REDIS_URL=redis://tt-redis:6379/0
