# ── Deployment ────────────────────────────────────────────────────────────────
DEPLOYMENT_NAME=tigers-local
PUBLIC_BASE_URL=http://localhost:8080
TIGERS_VERSION=v0.2.0
CADDY_CONFIG_DIR=caddy-local

# ── Shared Secrets (alle Services) ────────────────────────────────────────────
INTERNAL_API_SECRET=change-me-internal-api-secret
SSO_SHARED_SECRET=change-me-sso-shared-secret

# ── App Secret Keys ───────────────────────────────────────────────────────────
INFRA_SECRET_KEY=change-me-infra-secret
AUTH_SECRET_KEY=change-me-auth-secret
MEMBERS_SECRET_KEY=change-me-members-secret
AGENDA_SECRET_KEY=change-me-agenda-secret
ANALYTICS_SECRET_KEY=change-me-analytics-secret
ATTENDANCE_SECRET_KEY=change-me-attendance-secret

# ── Admin ─────────────────────────────────────────────────────────────────────
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin

# ── Datenbank-Passwörter ──────────────────────────────────────────────────────
POSTGRES_INFRA_PASSWORD=tt_infra_password
POSTGRES_AUTH_PASSWORD=tt_auth_password
POSTGRES_MEMBERS_PASSWORD=tt_members_password
POSTGRES_AGENDA_PASSWORD=tt_agenda_password
POSTGRES_ATTENDANCE_PASSWORD=tt_attendance_password
POSTGRES_ANALYTICS_PASSWORD=tt_analytics_password

# ── Datenbank-URLs (werden aus Passwörtern oben aufgebaut) ────────────────────
INFRA_DATABASE_URL=postgresql+psycopg://tt_infra:tt_infra_password@tt-postgres:5432/tt_infra
AUTH_DATABASE_URL=postgresql+psycopg://tt_auth:tt_auth_password@tt-postgres:5432/tt_auth
MEMBERS_DATABASE_URL=postgresql+psycopg://tt_members:tt_members_password@tt-postgres:5432/tt_members
AGENDA_DATABASE_URL=postgresql+psycopg://tt_agenda:tt_agenda_password@tt-postgres:5432/tt_agenda
ATTENDANCE_DATABASE_URL=postgresql+psycopg://tt_attendance:tt_attendance_password@tt-postgres:5432/tt_attendance
ANALYTICS_DATABASE_URL=postgresql+psycopg://tt_analytics:tt_analytics_password@tt-postgres:5432/tt_analytics

# ── Optionale Features ────────────────────────────────────────────────────────
# ANALYTICS_GEMINI_API_KEY=
# AGENDA_WEBHOOK_ENABLED=false
# AGENDA_WEBHOOK_URL=
