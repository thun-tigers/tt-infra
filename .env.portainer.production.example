GHCR_OWNER=thun-tigers
GHCR_REGISTRY=ghcr.io

# Release-Manifest aus tt-infra/releases uebernehmen.
# Beispiel fuer den gemeinsamen Plattform-Start:
TT_INFRA_IMAGE_TAG=v0.1.0
TT_AUTH_IMAGE_TAG=v0.1.0
TT_MEMBERS_IMAGE_TAG=v0.1.0
TT_AGENDA_IMAGE_TAG=v0.1.0
TT_ANALYTICS_IMAGE_TAG=v0.1.0
TT_ATTENDANCE_IMAGE_TAG=v0.1.0

TZ=Europe/Zurich
LOG_LEVEL=INFO
TRAEFIK_HTTP_PORT=80
TRAEFIK_LOG_LEVEL=INFO
CLOUDFLARE_TUNNEL_TOKEN=

INFRA_SECRET_KEY=
INFRA_DATABASE_URL=postgresql+psycopg://tt_infra:change-me@tt-postgres-infra:5432/tt_infra
INTERNAL_API_SECRET=
SSO_SHARED_SECRET=

AUTH_SECRET_KEY=
AUTH_DATABASE_URL=postgresql+psycopg://tt_auth:change-me@tt-postgres-auth:5432/tt_auth
JWT_EXPIRY_HOURS=8
JWT_COOKIE_DOMAIN=.thun-tigers.net
JWT_COOKIE_SECURE=true
SSO_TOKEN_EXPIRY_SECONDS=60
CREATE_DEFAULT_USERS=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_MEMBERS_URL=https://members.thun-tigers.net
DEFAULT_AGENDA_URL=https://agenda.thun-tigers.net
DEFAULT_ANALYTICS_URL=https://analytics.thun-tigers.net
DEFAULT_ATTENDANCE_URL=https://attendance.thun-tigers.net

MEMBERS_SECRET_KEY=
MEMBERS_DATABASE_URL=postgresql+psycopg://tt_members:change-me@tt-postgres-members:5432/tt_members
MEMBERS_AUTH_BASE_URL=https://auth.thun-tigers.net

AGENDA_SECRET_KEY=
AGENDA_DATABASE_URL=postgresql+psycopg://tt_agenda:change-me@tt-postgres-agenda:5432/tt_agenda
AGENDA_AUTH_BASE_URL=https://auth.thun-tigers.net
AGENDA_WEBHOOK_ENABLED=false
AGENDA_WEBHOOK_URL=
AGENDA_SSO_AUTO_PROVISION_USERS=true
AGENDA_SSO_SYNC_ROLE=true

ANALYTICS_SECRET_KEY=
ANALYTICS_DATABASE_URL=postgresql+psycopg://tt_analytics:change-me@tt-postgres-analytics:5432/tt_analytics
ANALYTICS_AUTH_BASE_URL=https://auth.thun-tigers.net
ANALYTICS_SSO_AUTO_PROVISION_USERS=true
ANALYTICS_SSO_SYNC_ROLE=true
ANALYTICS_MAX_CONTENT_LENGTH=2147483648
ANALYTICS_GEMINI_API_KEY=
ANALYTICS_GEMINI_MODEL=gemini-2.5-flash
ANALYTICS_GEMINI_FILE_POLL_SECONDS=5
ANALYTICS_GEMINI_FILE_POLL_TIMEOUT_SECONDS=300
ANALYTICS_GEMINI_MAX_RETRIES=8
ANALYTICS_GEMINI_RETRY_BUFFER_SECONDS=5
ANALYTICS_GEMINI_RETRY_DEFAULT_SECONDS=60

ATTENDANCE_SECRET_KEY=
ATTENDANCE_DATABASE_URL=postgresql+psycopg://tt_attendance:change-me@tt-postgres-attendance:5432/tt_attendance
ATTENDANCE_AUTH_BASE_URL=https://auth.thun-tigers.net

POSTGRES_AUTH_DB=tt_auth
POSTGRES_AUTH_USER=tt_auth
POSTGRES_AUTH_PASSWORD=

POSTGRES_INFRA_DB=tt_infra
POSTGRES_INFRA_USER=tt_infra
POSTGRES_INFRA_PASSWORD=

POSTGRES_MEMBERS_DB=tt_members
POSTGRES_MEMBERS_USER=tt_members
POSTGRES_MEMBERS_PASSWORD=

POSTGRES_AGENDA_DB=tt_agenda
POSTGRES_AGENDA_USER=tt_agenda
POSTGRES_AGENDA_PASSWORD=
POSTGRES_ANALYTICS_DB=tt_analytics
POSTGRES_ANALYTICS_USER=tt_analytics
POSTGRES_ANALYTICS_PASSWORD=

POSTGRES_ATTENDANCE_DB=tt_attendance
POSTGRES_ATTENDANCE_USER=tt_attendance
POSTGRES_ATTENDANCE_PASSWORD=
